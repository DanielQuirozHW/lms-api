# =============================================================================
# Application
# =============================================================================
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# =============================================================================
# Database — PostgreSQL 16
# Full connection string including credentials, host, port, and database name.
# connection_limit: Prisma connection pool size (default is 5 — far too low for production).
#   Set to ~20 for a single Railway dyno; increase proportionally with horizontal scale.
# pool_timeout: seconds to wait for a free connection before throwing (default 10).
# =============================================================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/lms_db?connection_limit=20&pool_timeout=30

# =============================================================================
# Redis 7
# Used for refresh token storage, rate limit state, and pub/sub.
# Leave REDIS_PASSWORD empty for local dev with no auth.
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# JWT
# Both secrets must be at least 32 characters (enforced at startup).
# Access tokens are short-lived; refresh tokens are long-lived and stored in Redis.
# =============================================================================
JWT_SECRET=change-me-to-a-random-32-char-secret-key
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-a-different-random-32-char-secret
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# CORS
# Comma-separated list of allowed origins. No trailing slashes.
# =============================================================================
CORS_ORIGINS=http://localhost:3001,http://localhost:5173

# =============================================================================
# Rate Limiting
# THROTTLE_TTL: time window in milliseconds (default: 60 seconds)
# THROTTLE_LIMIT: max requests per window per IP (default: 100)
# Auth endpoints (login, register, refresh) override this with 5 req / 60s.
# =============================================================================
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# =============================================================================
# Cloudflare R2 — S3-compatible file storage
# Leave all R2_* values empty to disable file upload features.
# R2_PUBLIC_URL: the public CDN base URL for uploaded files (no trailing slash).
# =============================================================================
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=lms-assets
R2_PUBLIC_URL=https://assets.yourdomain.com

# =============================================================================
# Swagger UI
# Set to true only in development or staging environments.
# Never enable in production — exposes full API schema to the public.
# =============================================================================
SWAGGER_ENABLED=false
