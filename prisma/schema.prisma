generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum LessonType {
  VIDEO
  TEXT
  QUIZ
  ASSIGNMENT
}

enum QuestionType {
  MULTIPLE_CHOICE
  SINGLE_CHOICE
  TRUE_FALSE
  SHORT_TEXT
  LONG_TEXT
}

enum GradingType {
  AUTOMATIC
  MANUAL
}

enum RatingScale {
  STARS_5
  NUMERIC_10
  NUMERIC_100
}

enum NotificationType {
  ENROLLMENT
  NEW_LESSON
  FORUM_REPLY
  ASSIGNMENT_GRADED
  QUIZ_PASSED
  QUIZ_FAILED
  COURSE_COMPLETED
  ANNOUNCEMENT
}

enum CalendarEventType {
  ASSIGNMENT_DUE
  QUIZ_DUE
  LESSON_AVAILABLE
  COURSE_START
  COURSE_END
  CUSTOM
}

enum GlobalAnnouncementType {
  INFO
  WARNING
  MAINTENANCE
  SUCCESS
}

enum EnrollmentType {
  FREE
  ASSIGNED
  CODE
  PAID
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum SubmissionStatus {
  SUBMITTED
  GRADING
  GRADED
  RETURNED
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  firstName    String     @map("first_name")
  lastName     String     @map("last_name")
  avatarUrl    String?    @map("avatar_url")
  roles             UserRole[] @default([STUDENT])
  isVerified        Boolean    @default(false) @map("is_verified")
  passwordChangedAt DateTime?  @map("password_changed_at")
  isActive          Boolean    @default(true) @map("is_active")
  phone             String?    @map("phone")
  birthDate         DateTime?  @map("birth_date")
  location          String?    @map("location")
  bio               String?    @map("bio")
  preferredLanguage String     @default("es") @map("preferred_language")
  preferredTheme    String     @default("dark") @map("preferred_theme")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  notificationSettings      NotificationSettings?
  notificationPreferences   NotificationPreferences?
  taughtCourses             Course[]              @relation("CourseInstructor")
  enrollments           Enrollment[]
  notifications         Notification[]
  threads               ForumThread[]
  posts                 ForumPost[]
  postVotes             ForumPostVote[]
  sentMessages          Message[]             @relation("SentMessages")
  receivedMessages      Message[]             @relation("ReceivedMessages")
  courseRatings         CourseRating[]
  announcements         Announcement[]        @relation("AnnouncementInstructor")
  gradedSubmissions     Submission[]          @relation("SubmissionGrader")
  rubricAssessments     RubricAssessment[]
  groupMemberships      CourseGroupMember[]
  calendarEvents        CalendarEvent[]
  globalAnnouncements   GlobalAnnouncement[]
  lessonNotes           LessonNote[]
  lessonBookmarks       LessonBookmark[]
  certificates          Certificate[]
  resetTokens           PasswordResetToken[]
  adminImpersonations   ImpersonationLog[]   @relation("AdminImpersonations")
  targetImpersonations  ImpersonationLog[]   @relation("TargetImpersonations")
  codeUsages            EnrollmentCodeUsage[]
  loginEvents           LoginEvent[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("password_reset_tokens")
}

model NotificationPreferences {
  id                   String   @id @default(cuid())
  userId               String   @unique @map("user_id")
  lessonRemindersEmail Boolean  @default(true)  @map("lesson_reminders_email")
  lessonRemindersPush  Boolean  @default(true)  @map("lesson_reminders_push")
  newCoursesEmail      Boolean  @default(false) @map("new_courses_email")
  newCoursesPush       Boolean  @default(true)  @map("new_courses_push")
  forumRepliesEmail    Boolean  @default(true)  @map("forum_replies_email")
  forumRepliesPush     Boolean  @default(true)  @map("forum_replies_push")
  achievementsEmail    Boolean  @default(true)  @map("achievements_email")
  achievementsPush     Boolean  @default(true)  @map("achievements_push")
  platformNewsEmail    Boolean  @default(false) @map("platform_news_email")
  platformNewsPush     Boolean  @default(false) @map("platform_news_push")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt      @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model NotificationSettings {
  id                      String   @id @default(cuid())
  userId                  String   @unique @map("user_id")
  emailOnEnrollment       Boolean  @default(true) @map("email_on_enrollment")
  emailOnNewLesson        Boolean  @default(true) @map("email_on_new_lesson")
  emailOnForumReply       Boolean  @default(true) @map("email_on_forum_reply")
  emailOnAssignmentGraded Boolean  @default(true) @map("email_on_assignment_graded")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_settings")
}

// ─── Course ───────────────────────────────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  courses Course[]

  @@map("categories")
}

model Course {
  id           String       @id @default(cuid())
  title        String
  slug         String       @unique
  description  String?
  coverUrl     String?      @map("cover_url")
  status             CourseStatus   @default(DRAFT)
  enrollmentType     EnrollmentType @default(FREE)  @map("enrollment_type")
  price              Decimal?       @db.Decimal(10, 2)
  instructorId       String         @map("instructor_id")
  categoryId         String?        @map("category_id")
  level              CourseLevel    @default(BEGINNER) @map("level")
  whatYouWillLearn   String[]       @map("what_you_will_learn")
  tags               String[]       @default([]) @map("tags")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  instructor          User                @relation("CourseInstructor", fields: [instructorId], references: [id])
  category            Category?           @relation(fields: [categoryId], references: [id])
  settings            CourseSettings?
  modules             CourseModule[]
  enrollments         Enrollment[]
  ratings             CourseRating[]
  threads             ForumThread[]
  announcements       Announcement[]
  gradebookCategories GradebookCategory[]
  rubrics             Rubric[]
  groups              CourseGroup[]
  calendarEvents      CalendarEvent[]
  certificates        Certificate[]
  enrollmentCodes     EnrollmentCode[]

  @@index([instructorId])
  @@index([categoryId])
  @@index([status])
  @@map("courses")
}

model CourseSettings {
  id                  String      @id @default(cuid())
  courseId            String      @unique @map("course_id")
  enrollmentStartDate DateTime?   @map("enrollment_start_date")
  enrollmentEndDate   DateTime?   @map("enrollment_end_date")
  courseStartDate     DateTime?   @map("course_start_date")
  hasModules          Boolean     @default(true) @map("has_modules")
  forumEnabled        Boolean     @default(true) @map("forum_enabled")
  forumPublic         Boolean     @default(false) @map("forum_public")
  certificateEnabled  Boolean     @default(false) @map("certificate_enabled")
  ratingEnabled       Boolean     @default(true) @map("rating_enabled")
  ratingScale         RatingScale @default(STARS_5) @map("rating_scale")
  maxEnrollments      Int?        @map("max_enrollments")
  isSequential        Boolean     @default(false) @map("is_sequential")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("course_settings")
}

model CourseModule {
  id              String   @id @default(cuid())
  courseId        String   @map("course_id")
  title           String
  description     String?
  order           Int
  isPublished     Boolean  @default(false) @map("is_published")
  unlockAfterDays Int?     @map("unlock_after_days")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@unique([courseId, order])
  @@index([courseId])
  @@map("course_modules")
}

// ─── Lesson ───────────────────────────────────────────────────────────────────

model Lesson {
  id          String     @id @default(cuid())
  moduleId    String     @map("module_id")
  title       String
  order       Int
  type        LessonType @default(TEXT)
  content     String?
  videoUrl    String?    @map("video_url")
  duration    Int?
  readingTime Int?       @map("reading_time")
  isPreview   Boolean    @default(false) @map("is_preview")
  isPublished Boolean    @default(false) @map("is_published")
  rubricId    String?    @map("rubric_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  module             CourseModule        @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  quizSettings       QuizSettings?
  assignmentSettings AssignmentSettings?
  questions          Question[]
  resources          LessonResource[]
  progress           LessonProgress[]
  quizAttempts       QuizAttempt[]
  submissions        Submission[]
  gradebookItem      GradebookItem?
  rubric             Rubric?             @relation(fields: [rubricId], references: [id], onDelete: SetNull)
  notes              LessonNote[]
  bookmarks          LessonBookmark[]

  @@unique([moduleId, order])
  @@index([moduleId])
  @@map("lessons")
}

model LessonResource {
  id        String   @id @default(cuid())
  lessonId  String   @map("lesson_id")
  title     String
  url       String
  type      String
  createdAt DateTime @default(now()) @map("created_at")

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("lesson_resources")
}

// ─── Quiz ─────────────────────────────────────────────────────────────────────

model QuizSettings {
  id               String   @id @default(cuid())
  lessonId         String   @unique @map("lesson_id")
  maxAttempts      Int?     @map("max_attempts")
  passingScore     Int?     @map("passing_score")
  blocksProgress   Boolean  @default(false) @map("blocks_progress")
  shuffleQuestions Boolean  @default(false) @map("shuffle_questions")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("quiz_settings")
}

model Question {
  id        String       @id @default(cuid())
  lessonId  String       @map("lesson_id")
  text      String
  type      QuestionType
  order     Int
  points    Int          @default(1)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  lesson  Lesson           @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  options QuestionOption[]
  answers QuizAnswer[]

  @@unique([lessonId, order])
  @@index([lessonId])
  @@map("questions")
}

model QuestionOption {
  id         String   @id @default(cuid())
  questionId String   @map("question_id")
  text       String
  isCorrect  Boolean  @default(false) @map("is_correct")
  order      Int
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  question Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers  QuizAnswer[]

  @@unique([questionId, order])
  @@index([questionId])
  @@map("question_options")
}

model QuizAttempt {
  id            String    @id @default(cuid())
  enrollmentId  String    @map("enrollment_id")
  lessonId      String    @map("lesson_id")
  score         Float?
  attemptNumber Int       @map("attempt_number")
  startedAt     DateTime  @default(now()) @map("started_at")
  completedAt   DateTime? @map("completed_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  enrollment Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  answers    QuizAnswer[]

  @@unique([enrollmentId, lessonId, attemptNumber])
  @@index([enrollmentId])
  @@index([lessonId])
  @@map("quiz_attempts")
}

model QuizAnswer {
  id               String   @id @default(cuid())
  attemptId        String   @map("attempt_id")
  questionId       String   @map("question_id")
  selectedOptionId String?  @map("selected_option_id")
  textAnswer       String?  @map("text_answer")
  createdAt        DateTime @default(now()) @map("created_at")

  attempt        QuizAttempt     @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption QuestionOption? @relation(fields: [selectedOptionId], references: [id], onDelete: SetNull)

  @@index([attemptId])
  @@index([questionId])
  @@map("quiz_answers")
}

// ─── Assignment ───────────────────────────────────────────────────────────────

model AssignmentSettings {
  id                  String      @id @default(cuid())
  lessonId            String      @unique @map("lesson_id")
  gradingType         GradingType @default(MANUAL) @map("grading_type")
  maxScore            Int         @map("max_score")
  passingScore        Int?        @map("passing_score")
  dueDate             DateTime?   @map("due_date")
  allowLateSubmission Boolean     @default(false) @map("allow_late_submission")
  isGroupAssignment   Boolean     @default(false) @map("is_group_assignment")
  groupId             String?     @map("group_id")
  maxAttempts         Int?        @map("max_attempts")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  lesson Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  group  CourseGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([groupId])
  @@map("assignment_settings")
}

model Submission {
  id            String           @id @default(cuid())
  enrollmentId  String           @map("enrollment_id")
  lessonId      String           @map("lesson_id")
  content       String
  fileUrl       String?          @map("file_url")
  submittedAt   DateTime         @default(now()) @map("submitted_at")
  attemptNumber Int              @map("attempt_number")
  status        SubmissionStatus @default(SUBMITTED) @map("status")
  grade         Int?
  feedback      String?
  gradedById    String?          @map("graded_by_id")
  gradedAt      DateTime?        @map("graded_at")
  groupId       String?          @map("group_id")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  enrollment       Enrollment        @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson           Lesson            @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  gradedBy         User?             @relation("SubmissionGrader", fields: [gradedById], references: [id], onDelete: SetNull)
  group            CourseGroup?      @relation(fields: [groupId], references: [id], onDelete: SetNull)
  rubricAssessment RubricAssessment?

  @@unique([enrollmentId, lessonId, attemptNumber])
  @@index([enrollmentId])
  @@index([lessonId])
  @@index([gradedById])
  @@index([groupId])
  @@map("submissions")
}

// ─── Enrollment & Progress ────────────────────────────────────────────────────

model Enrollment {
  id          String           @id @default(cuid())
  userId      String           @map("user_id")
  courseId    String           @map("course_id")
  status      EnrollmentStatus @default(ACTIVE)
  completedAt DateTime?        @map("completed_at")
  enrolledAt  DateTime         @default(now()) @map("enrolled_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  finalGrade  Float?           @map("final_grade")
  gradedAt    DateTime?        @map("graded_at")

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course       Course           @relation(fields: [courseId], references: [id])
  progress     LessonProgress[]
  quizAttempts QuizAttempt[]
  submissions  Submission[]
  certificate  Certificate?

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("enrollments")
}

model LessonProgress {
  id             String    @id @default(cuid())
  enrollmentId   String    @map("enrollment_id")
  lessonId       String    @map("lesson_id")
  isLocked       Boolean   @default(false) @map("is_locked")
  startedAt      DateTime? @map("started_at")
  completedAt    DateTime? @map("completed_at")
  lastWatchedAt  DateTime? @map("last_watched_at")
  watchedSeconds Int?      @map("watched_seconds")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@index([enrollmentId])
  @@index([lessonId])
  @@map("lesson_progress")
}

// ─── Forum ────────────────────────────────────────────────────────────────────

model ForumThread {
  id        String   @id @default(cuid())
  title     String
  courseId  String?  @map("course_id")
  authorId  String   @map("author_id")
  isPinned  Boolean  @default(false) @map("is_pinned")
  isClosed  Boolean  @default(false) @map("is_closed")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  course Course?     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  author User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  posts  ForumPost[]

  @@index([courseId])
  @@index([authorId])
  @@map("forum_threads")
}

model ForumPost {
  id               String   @id @default(cuid())
  threadId         String   @map("thread_id")
  authorId         String   @map("author_id")
  content          String
  parentId         String?  @map("parent_id")
  isAcceptedAnswer Boolean  @default(false) @map("is_accepted_answer")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  thread  ForumThread    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author  User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  ForumPost?     @relation("PostReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies ForumPost[]    @relation("PostReplies")
  votes   ForumPostVote[]

  @@index([threadId])
  @@index([authorId])
  @@index([parentId])
  @@map("forum_posts")
}

model ForumPostVote {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  value     Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@map("forum_post_votes")
}

// ─── Announcements ────────────────────────────────────────────────────────────

model Announcement {
  id           String   @id @default(cuid())
  courseId     String   @map("course_id")
  instructorId String   @map("instructor_id")
  title        String
  body         String
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  course     Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  instructor User   @relation("AnnouncementInstructor", fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([instructorId])
  @@map("announcements")
}

// ─── Ratings ─────────────────────────────────────────────────────────────────

model CourseRating {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  courseId  String   @map("course_id")
  score     Float
  review    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
  @@map("course_ratings")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id            String           @id @default(cuid())
  userId        String           @map("user_id")
  type          NotificationType
  title         String
  body          String
  isRead        Boolean          @default(false) @map("is_read")
  referenceId   String?          @map("reference_id")
  referenceType String?          @map("reference_type")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@map("notifications")
}

// ─── Messages ─────────────────────────────────────────────────────────────────

model Message {
  id         String    @id @default(cuid())
  senderId   String    @map("sender_id")
  receiverId String    @map("receiver_id")
  content    String
  readAt     DateTime? @map("read_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([senderId, receiverId])
  @@index([readAt])
  @@map("messages")
}

// ─── Gradebook ────────────────────────────────────────────────────────────────

model GradebookCategory {
  id        String   @id @default(cuid())
  courseId  String   @map("course_id")
  name      String
  weight    Float
  order     Int
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  course Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  items  GradebookItem[]

  @@unique([courseId, name])
  @@index([courseId])
  @@map("gradebook_categories")
}

model GradebookItem {
  id            String   @id @default(cuid())
  categoryId    String   @map("category_id")
  lessonId      String   @unique @map("lesson_id")
  weight        Float?
  maxScore      Float    @map("max_score")
  isExtraCredit Boolean  @default(false) @map("is_extra_credit")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  category GradebookCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  lesson   Lesson            @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@map("gradebook_items")
}

// ─── Rubrics ──────────────────────────────────────────────────────────────────

model Rubric {
  id          String   @id @default(cuid())
  courseId    String   @map("course_id")
  title       String
  description String?
  totalPoints Int      @map("total_points")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  course      Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  criteria    RubricCriterion[]
  assessments RubricAssessment[]
  lessons     Lesson[]

  @@index([courseId])
  @@map("rubrics")
}

model RubricCriterion {
  id          String   @id @default(cuid())
  rubricId    String   @map("rubric_id")
  title       String
  description String?
  order       Int
  points      Int
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  rubric  Rubric                   @relation(fields: [rubricId], references: [id], onDelete: Cascade)
  levels  RubricLevel[]
  answers RubricAssessmentAnswer[]

  @@unique([rubricId, order])
  @@map("rubric_criteria")
}

model RubricLevel {
  id          String   @id @default(cuid())
  criterionId String   @map("criterion_id")
  title       String
  description String?
  points      Int
  order       Int
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  criterion RubricCriterion          @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  answers   RubricAssessmentAnswer[]

  @@unique([criterionId, order])
  @@map("rubric_levels")
}

model RubricAssessment {
  id           String   @id @default(cuid())
  rubricId     String   @map("rubric_id")
  submissionId String   @unique @map("submission_id")
  assessorId   String   @map("assessor_id")
  totalScore   Float    @map("total_score")
  feedback     String?
  assessedAt   DateTime @map("assessed_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  rubric     Rubric                   @relation(fields: [rubricId], references: [id], onDelete: Cascade)
  submission Submission               @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  assessor   User                     @relation(fields: [assessorId], references: [id])
  answers    RubricAssessmentAnswer[]

  @@index([rubricId])
  @@index([assessorId])
  @@map("rubric_assessments")
}

model RubricAssessmentAnswer {
  id            String   @id @default(cuid())
  assessmentId  String   @map("assessment_id")
  criterionId   String   @map("criterion_id")
  levelId       String?  @map("level_id")
  pointsAwarded Float    @map("points_awarded")
  feedback      String?
  createdAt     DateTime @default(now()) @map("created_at")

  assessment RubricAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  criterion  RubricCriterion  @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  level      RubricLevel?     @relation(fields: [levelId], references: [id], onDelete: SetNull)

  @@unique([assessmentId, criterionId])
  @@map("rubric_assessment_answers")
}

// ─── Groups ───────────────────────────────────────────────────────────────────

model CourseGroup {
  id          String   @id @default(cuid())
  courseId    String   @map("course_id")
  name        String
  description String?
  maxMembers  Int?     @map("max_members")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  course             Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  members            CourseGroupMember[]
  submissions        Submission[]
  assignmentSettings AssignmentSettings[]

  @@unique([courseId, name])
  @@index([courseId])
  @@map("course_groups")
}

model CourseGroupMember {
  id       String   @id @default(cuid())
  groupId  String   @map("group_id")
  userId   String   @map("user_id")
  joinedAt DateTime @default(now()) @map("joined_at")

  group CourseGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@map("course_group_members")
}

// ─── Calendar ─────────────────────────────────────────────────────────────────

model CalendarEvent {
  id            String            @id @default(cuid())
  courseId      String?           @map("course_id")
  userId        String            @map("user_id")
  title         String
  description   String?
  type          CalendarEventType
  startDate     DateTime          @map("start_date")
  endDate       DateTime?         @map("end_date")
  allDay        Boolean           @default(false) @map("all_day")
  color         String?
  referenceId   String?           @map("reference_id")
  referenceType String?           @map("reference_type")
  isActive      Boolean           @default(true) @map("is_active")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  course  Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)
  creator User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([userId])
  @@index([startDate])
  @@map("calendar_events")
}

// ─── GlobalAnnouncement ───────────────────────────────────────────────────────

model GlobalAnnouncement {
  id        String                 @id @default(cuid())
  title     String
  message   String
  type      GlobalAnnouncementType @default(INFO)
  isActive  Boolean                @default(true) @map("is_active")
  startsAt  DateTime?              @map("starts_at")
  endsAt    DateTime?              @map("ends_at")
  createdBy String                 @map("created_by")
  createdAt DateTime               @default(now()) @map("created_at")
  updatedAt DateTime               @updatedAt @map("updated_at")

  author User @relation(fields: [createdBy], references: [id])

  @@index([createdBy])
  @@index([isActive])
  @@map("global_announcements")
}

// ─── LessonNote ───────────────────────────────────────────────────────────────

model LessonNote {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  lessonId  String   @map("lesson_id")
  content   String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("lesson_notes")
}

// ─── LessonBookmark ───────────────────────────────────────────────────────────

model LessonBookmark {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  lessonId  String   @map("lesson_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("lesson_bookmarks")
}

// ─── Certificate ──────────────────────────────────────────────────────────────

model Certificate {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  courseId        String   @map("course_id")
  enrollmentId    String   @unique @map("enrollment_id")
  certificateCode String   @unique @default(cuid()) @map("certificate_code")
  issuedAt        DateTime @default(now()) @map("issued_at")
  finalGrade      Float?   @map("final_grade")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
  @@map("certificates")
}

// ─── EnrollmentCode ───────────────────────────────────────────────────────────

model EnrollmentCode {
  id        String    @id @default(cuid())
  courseId  String    @map("course_id")
  code      String    @unique
  maxUses   Int?      @map("max_uses")
  usedCount Int       @default(0) @map("used_count")
  expiresAt DateTime? @map("expires_at")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  course  Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  usages  EnrollmentCodeUsage[]

  @@index([courseId])
  @@index([code])
  @@map("enrollment_codes")
}

model EnrollmentCodeUsage {
  id        String         @id @default(cuid())
  codeId    String         @map("code_id")
  userId    String         @map("user_id")
  usedAt    DateTime       @default(now()) @map("used_at")

  code  EnrollmentCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([codeId, userId])
  @@index([codeId])
  @@index([userId])
  @@map("enrollment_code_usages")
}

// ─── ImpersonationLog ─────────────────────────────────────────────────────────

model ImpersonationLog {
  id           String    @id @default(cuid())
  adminId      String    @map("admin_id")
  targetUserId String    @map("target_user_id")
  startedAt    DateTime  @default(now()) @map("started_at")
  endedAt      DateTime? @map("ended_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  admin      User @relation("AdminImpersonations", fields: [adminId], references: [id])
  targetUser User @relation("TargetImpersonations", fields: [targetUserId], references: [id])

  @@index([adminId])
  @@index([targetUserId])
  @@map("impersonation_logs")
}

// ─── LoginEvent ───────────────────────────────────────────────────────────────

model LoginEvent {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("login_events")
}

// ─── SystemError ──────────────────────────────────────────────────────────────

model SystemError {
  id         String   @id @default(cuid())
  level      String   @default("ERROR")
  message    String
  stack      String?
  url        String?
  method     String?
  statusCode Int?
  userId     String?
  body       String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([statusCode])
  @@map("system_errors")
}
